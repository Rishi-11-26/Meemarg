{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MeeMarg Service Schema",
  "description": "JSON Schema for Telangana Government Services",
  "type": "object",
  "required": ["metadata", "services"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "last_updated", "total_services", "rate_revision_date"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of the data schema"
        },
        "last_updated": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last update"
        },
        "total_services": {
          "type": "integer",
          "minimum": 1,
          "description": "Total number of services in the dataset"
        },
        "rate_revision_date": {
          "type": "string",
          "format": "date",
          "description": "Date of last fee revision (YYYY-MM-DD)"
        },
        "data_source": {
          "type": "string",
          "description": "Official source of service information"
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/service"
      }
    },
    "change_log": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/change_entry"
      }
    }
  },
  "definitions": {
    "service": {
      "type": "object",
      "required": [
        "service_id",
        "name",
        "department",
        "category",
        "keywords",
        "fee",
        "required_documents",
        "processing_time",
        "is_revenue",
        "description_simple",
        "submission_modes",
        "priority_rank"
      ],
      "properties": {
        "service_id": {
          "type": "string",
          "pattern": "^[A-Z]{3}-\\d{3}$",
          "description": "Unique service identifier (e.g., REV-001, MUN-001)"
        },
        "name": {
          "type": "object",
          "required": ["en", "te"],
          "properties": {
            "en": {
              "type": "string",
              "minLength": 5,
              "description": "Service name in English"
            },
            "te": {
              "type": "string",
              "minLength": 3,
              "description": "Service name in Telugu"
            }
          }
        },
        "department": {
          "type": "string",
          "enum": [
            "Revenue",
            "Municipal",
            "Police",
            "Transport",
            "Civil Supplies",
            "Health",
            "Education",
            "Agriculture",
            "Labour",
            "Panchayat Raj"
          ],
          "description": "Parent government department"
        },
        "category": {
          "type": "string",
          "enum": ["A", "B", "E-Pass"],
          "description": "Fee category as per April 2026 revision"
        },
        "keywords": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 2
          },
          "description": "Search keywords for fuzzy matching"
        },
        "fee": {
          "type": "number",
          "minimum": 0,
          "description": "Service fee in Indian Rupees (₹)"
        },
        "required_documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "object",
                "required": ["en", "te"],
                "properties": {
                  "en": {"type": "string"},
                  "te": {"type": "string"}
                }
              },
              "type": {
                "type": "string",
                "enum": ["original", "copy", "self_attested", "digital"]
              },
              "mandatory": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "processing_time": {
          "type": "string",
          "pattern": "^(Instant|\\d+-\\d+ (Days|Hours)|\\d+ (Days|Weeks|Months))$",
          "description": "Expected service delivery time"
        },
        "is_revenue": {
          "type": "boolean",
          "description": "If true, triggers ₹2 Court Stamp requirement for MeeSeva"
        },
        "description_simple": {
          "type": "object",
          "required": ["en", "te"],
          "properties": {
            "en": {
              "type": "string",
              "minLength": 20,
              "description": "Plain-language description in English"
            },
            "te": {
              "type": "string",
              "minLength": 10,
              "description": "Plain-language description in Telugu"
            }
          }
        },
        "submission_modes": {
          "type": "object",
          "required": ["online", "meeseva_center"],
          "properties": {
            "online": {
              "type": "object",
              "required": ["available", "portal_url"],
              "properties": {
                "available": {"type": "boolean"},
                "portal_url": {"type": "string", "format": "uri"},
                "requires_digital_signature": {"type": "boolean", "default": false}
              }
            },
            "meeseva_center": {
              "type": "object",
              "required": ["available", "requires_stamp"],
              "properties": {
                "available": {"type": "boolean"},
                "requires_stamp": {"type": "boolean"},
                "stamp_value": {"type": "number", "default": 2}
              }
            }
          }
        },
        "priority_rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30,
          "description": "Usage frequency ranking (1 = most used)"
        },
        "related_services": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{3}-\\d{3}$"
          },
          "description": "Array of related service IDs"
        }
      }
    },
    "change_entry": {
      "type": "object",
      "required": ["timestamp", "service_id", "field_changed", "old_value", "new_value", "source"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "service_id": {
          "type": "string",
          "pattern": "^[A-Z]{3}-\\d{3}$"
        },
        "field_changed": {
          "type": "string"
        },
        "old_value": {},
        "new_value": {},
        "source": {
          "type": "string",
          "enum": ["scout_agent.py", "manual_update", "gazette_notification"]
        },
        "verified_by": {
          "type": "string"
        }
      }
    }
  }
}
